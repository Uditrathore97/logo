{
  "nodes": [
    {
      "id": "Start",
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "position": [200, 300]
    },
    {
      "id": "Set Data",
      "name": "Set Data",
      "type": "n8n-nodes-base.set",
      "position": [400, 300],
      "parameters": {
        "values": {
          "string": [
            { "name": "subject", "value": "Economic & Social Issues" },
            { "name": "chapter", "value": "Economic Growth and Development" },
            { "name": "title", "value": "RBI One | National News | January 2026" },
            { "name": "content", "value": "Automated content converted into PDF using n8n." }
          ]
        }
      }
    },
    {
      "id": "Generate HTML",
      "name": "Generate HTML",
      "type": "n8n-nodes-base.function",
      "position": [600, 300],
      "parameters": {
        "functionCode": "const html = `<!DOCTYPE html><html><body><h1>${$json.title}</h1><p>${$json.content}</p></body></html>`;\nreturn [{ html }];"
      }
    },
    {
      "id": "HTML to PDF",
      "name": "HTML to PDF",
      "type": "n8n-nodes-base.htmlPdf",
      "position": [800, 300],
      "parameters": {
        "html": "={{$json[\"html\"]}}",
        "options": {
          "format": "A4"
        }
      }
    },
    {
      "id": "Write File",
      "name": "Save PDF",
      "type": "n8n-nodes-base.writeBinaryFile",
      "position": [1000, 300],
      "parameters": {
        "fileName": "output/report.pdf",
        "dataPropertyName": "data"
      }
    }
  ],
  "connections": {
    "Start": {
      "main": [[{ "node": "Set Data", "type": "main", "index": 0 }]]
    },
    "Set Data": {
      "main": [[{ "node": "Generate HTML", "type": "main", "index": 0 }]]
    },
    "Generate HTML": {
      "main": [[{ "node": "HTML to PDF", "type": "main", "index": 0 }]]
    },
    "HTML to PDF": {
      "main": [[{ "node": "Save PDF", "type": "main", "index": 0 }]]
    }
  }
}
